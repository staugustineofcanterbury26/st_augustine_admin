# Copy to .env and fill in values

# Backend API (st_augustine_backend on Render, separate repo)
VITE_API_URL=https://your-backend.onrender.com

# Vercel Blob CDN base URL
VITE_BLOB_BASE_URL=https://your-project.public.blob.vercel-storage.com

# URL to the public frontend (shown in "View Site" button)
VITE_FRONTEND_URL=https://your-parish.vercel.app
